<settings>
<category label="General">
          <setting id="allow_self_signed" type="bool" label="Allow self-signed certificates" default="false" />
          <setting id="items_per_page" type="number" label="Items per page" default="25" />
 </category>
    <category label="Seerr">
        <setting id="seerr_url" type="text" label="Server URL" default="http://localhost:5055" />
        <setting id="seerr_auth_method" type="select" label="Seerr Auth Method" values="API-Key|Plex|Jellyfin|Seerr" />
        <setting id="seerr_api_token" type="text" label="API Token" default="" visible="eq(-1,0)" />
        <setting id="seerr_plex_token" type="text" label="Plex Token" default="" visible="eq(-2,1)" />
        <setting id="seerr_jellyfin_username" type="text" label="Jellyfin Username" default="" visible="eq(-3,2)" />
        <setting id="seerr_jellyfin_password" type="text" label="Jellyfin Password" default="" visible="eq(-4,2)" />
        <setting id="seerr_local_email" type="text" label="Seerr E-mail" default="" visible="eq(-5,3)" />
        <setting id="seerr_local_password" type="text" label="Seerr Password" default="" visible="eq(-6,3)" />
    </category>
    <category label="Radarr">
        <setting id="radarr_populate" type="action" label="Populate using Seerr" action="RunScript(plugin.video.seerr4kodi,populate_radarr_settings)" />
        <setting id="radarr_enable" type="bool" label="Enable Radarr functionality" default=false />
        <setting id="radarr_url" type="text" label="Server URL" default="http://localhost:7878" />
        <setting id="radarr_api_token" type="text" label="Radarr API Token" default="" />
        <setting id="radarr_has_4k" type="bool" label="Enable 4k Radarr server support" default=false />
        <setting id="radarr_url_4k" type="text" label="4k Radarr URL" default="http://localhost:7878" />
        <setting id="radarr_api_token_4k" type="text" label="4k Radarr API Token" default="" />
    </category>
      <category label="Sonarr">
        <setting id="sonarr_populate" type="action" label="Populate using Seerr" action="RunScript(plugin.video.seerr4kodi,populate_sonarr_settings)" />
        <setting id="sonarr_enable" type="bool" label="Enable Sonarr functionality" default=false />
        <setting id="sonarr_url" type="text" label="Server URL" default="http://localhost:8989" />
        <setting id="sonarr_api_token" type="text" label="Server API Token" default="" />
        <setting id="sonarr_has_4k" type="bool" label="Enable 4k Sonarr server support" default=false />
        <setting id="sonarr_url_4k" type="text" label="4k Server URL" default="http://localhost:8989" />
        <setting id="sonarr_api_token_4k" type="text" label="4k Server API Token" default="" />
    </category>
    <category label="Trakt">
     <setting id="trakt_auth" type="action" label="Authenticate" action="RunScript(plugin.video.seerr4kodi,trakt_login)" />
    </category>
    <category label="ntfy.sh">
    <setting id="ntfy_enable" type="bool" label="Enable ntfy.sh notifications" default=false />
     <setting id="ntfy_url" type="text" label="ntfy.sh server url" default="https://ntfy.sh" />
     <setting id="ntfy_topic" type="text" label="ntfy.sh topic" default="" />
     </category>
    <category label="Requests">
        <setting id="enable_ask_4k" type="bool" label="Enable asking for 4K" default="false" />
        <setting id="show_quality_profiles" type="bool" label="Show quality profile selection" default="true" />
        <setting id="remember_last_quality" type="bool" label="Remember last quality choice" default="true" />
        <setting id="enable_season_selection" type="bool" label="Enable TV season selection" default="true" />
        <setting id="confirm_before_request" type="bool" label="Confirm before requesting" default="true" />
        <setting id="show_request_status" type="bool" label="Show request status indicators" default="true" />
    </category>
    <category label="Notifications">
        <setting id="enable_request_notifications" type="bool" label="Enable Request Notifications" default="false" />
        <setting id="polling_interval" type="number" label="Polling Interval (Seconds)" default="60" />
        <setting id="notify_processing" type="bool" label="Notify when processing starts" default="false" />
        <setting id="notify_approved" type="bool" label="Notify when request approved" default="false" />
    </category>
    <category label="Advanced">
        <setting id="enable_caching" type="bool" label="Enable API caching" default="true" />
        <setting id="cache_duration" type="number" label="Cache duration (Seconds)" default="300" />
        <setting id="clear_cache" type="action" label="Clear Cache" action="RunScript(plugin.video.seerr4kodi,clear_cache)" />
    </category>
</settings>
